# ═══════════════════════════════════════════════
#  ShadowBot .gitignore
# ═══════════════════════════════════════════════

# ── Python ──────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# ── Build / dist ────────────────────────────────
build/
dist/
*.egg-info/
*.egg
.eggs/
MANIFEST
wheels/
*.whl

# ── Virtual environments ─────────────────────────
.venv/
venv/
env/
ENV/
.env/

# ── Testing ──────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
*.log

# ── Type checkers ────────────────────────────────
.mypy_cache/
.pytype/
.ruff_cache/

# ── IDE ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ───────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── ShadowBot runtime data (JANGAN dicommit) ─────
~/.shadowbot/
.shadowbot/
*.db
*.db-shm
*.db-wal

# ── API keys / secrets ───────────────────────────
config.json
.env
.env.*
secrets.json
*.key
*.pem

# ── Workspace & memory (data user) ───────────────
workspace/
memory.db
knowledge.db
history

# ── Logs ─────────────────────────────────────────
logs/
*.log
nohup.out

# ── Packaging artifact ───────────────────────────
shadowbot.zip
*.tar.gz
